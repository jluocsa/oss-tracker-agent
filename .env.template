# =============================================================================
# OSS Tracker Agent — environment configuration
# Copy to `.env` and fill in. `.env` is gitignored.
# =============================================================================

# ---- Model (pick ONE block; comment the other) -----------------------------

# Option A: OpenAI (api.openai.com)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini

# Option B: Azure OpenAI (uncomment + fill in; also leave OPENAI_API_KEY blank)
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=<your-aoai-key>
# AZURE_OPENAI_CHAT_MODEL=<your-deployment-name>
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ---- Tracker paths ----------------------------------------------------------

# Path to the existing refresh script (defaults to ../refresh-oss-status.ps1)
REFRESH_SCRIPT=C:\Users\luojohn\github\jluocsa\refresh-oss-status.ps1

# GitHub user to track (matches the refresh script's --author filter)
GH_AUTHOR=jluocsa

# Comma-separated repos to skip
IGNORE_REPOS=jluocsa/Practice-Exam

# ---- Auto-action gates (true/false) -----------------------------------------

AUTO_RERUN_FAILED_CHECKS=true
AUTO_UPDATE_BRANCH=true

# ---- Email (Outlook / M365 SMTP) -------------------------------------------

NOTIFY_EMAIL_FROM=<your-outlook-address>@outlook.com
NOTIFY_EMAIL_TO=<your-outlook-address>@outlook.com
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=<your-outlook-address>@outlook.com
# Generate an app password at https://account.live.com/proofs/AppPassword
SMTP_PASSWORD=<your-app-password>

# Set to "true" to skip email even when human attention is needed (dry run)
EMAIL_DRY_RUN=false
